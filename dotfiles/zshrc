# --- Basic Environment ---
ITERM2_SQUELCH_MARK=1
export DISABLE_TELEMETRY=true
export GOPATH=$HOME/go
export BUN_INSTALL="$HOME/.bun"
export GHIDRA_INSTALL_DIR="/opt/homebrew/Caskroom/ghidra/10.3.1-20230614/ghidra_10.3.1_PUBLIC/"
export MMRANKHOSTS="$HOME/hacks/adventures/webhacks/majic/attack_surface.txt"
export MMRANKCSV="$HOME/hacks/adventures/webhacks/majic/top-domains-majestic.csv"

# --- Path Construction (Consolidated) ---
PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
PATH="$HOME/go/bin:$PATH"
PATH="$HOME/bin:$HOME/.docker/bin:$PATH"
PATH="$HOME/.cargo/bin:$PATH"
PATH="$HOME/.codon/bin:$PATH"
PATH="$HOME/.local/bin:$HOME/.pdtm/go/bin/:$PATH"
PATH="$HOME/.bun/bin:$PATH"
PATH="$HOME/.axiom/interact:$PATH"
PATH="$HOME/.cache/lm-studio/bin:$PATH"
PATH="$HOME/Library/Application Support/JetBrains/Toolbox/scripts:$PATH"
PATH="/opt/homebrew/opt/curl/bin:/opt/homebrew/opt/mysql-client/bin:/opt/homebrew/opt/ruby@3.0/bin:$PATH"
PATH="$HOME/.local/share/solana/install/active_release/bin:/Library/Frameworks/Mono.framework/Versions/Current/Commands:$PATH"
PATH="$HOME/.local/share/mise/shims:$PATH"
PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
PATH="$PATH:/Users/kod/.foundry/bin"
export PATH
export MANPATH="/opt/homebrew/opt/mysql-client/share/man:/opt/homebrew/opt/curl/share/man:/opt/homebrew/share/man:/usr/local/share/man:/usr/share/man:/Users/kod/.local/man"

# --- Vi Mode (replaces .inputrc for zsh) ---
bindkey -v
export KEYTIMEOUT=1

# Ctrl-L clears screen in both insert and command mode (matches .inputrc)
bindkey -M viins '^L' clear-screen
bindkey -M vicmd '^L' clear-screen

# Mode indicator + cursor shape (replaces show-mode-in-prompt from .inputrc)
vim_ins_mode="%F{green}i%f"
vim_cmd_mode="%F{blue}c%f"
vim_mode=$vim_ins_mode

zle-keymap-select() {
  case $KEYMAP in
    vicmd)      vim_mode=$vim_cmd_mode; print -n '\e[2 q' ;;
    viins|main) vim_mode=$vim_ins_mode; print -n '\e[6 q' ;;
  esac
  zle reset-prompt
}
zle-line-init() { vim_mode=$vim_ins_mode; print -n '\e[6 q'; }
zle -N zle-keymap-select
zle -N zle-line-init

# Restore some emacs-style bindings that are useful in insert mode
bindkey -M viins '^A' beginning-of-line
bindkey -M viins '^E' end-of-line
bindkey -M viins '^K' kill-line
bindkey -M viins '^W' backward-kill-word
bindkey -M viins '^R' history-incremental-search-backward
bindkey -M viins '^P' up-line-or-history
bindkey -M viins '^N' down-line-or-history
bindkey -M viins '^?' backward-delete-char
bindkey -M viins '^H' backward-delete-char

# --- Completion (lazy, cached — not the 760ms bash_completion disaster) ---
autoload -Uz compinit
if [[ -n $HOME/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS

# --- Aliases ---
